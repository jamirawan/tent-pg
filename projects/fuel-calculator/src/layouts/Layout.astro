---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title = 'Fuel Calculator | Northern Territory, Australia', description = 'Estimate your road trip costs across the NT' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
