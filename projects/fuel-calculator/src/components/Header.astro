---
interface Props {
  title?: string;
}

const { title = 'Northern Territory' } = Astro.props;
---

<header>
  <nav class="navbar">
    <a class="navbar__logo" href="#">
      <div class="logo-circle">
        <svg viewBox="0 0 40 40">
          <circle cx="20" cy="20" r="16" fill="none" stroke="#fff" stroke-width="1.5"/>
          <path d="M20 8 Q26 14 26 20 Q26 26 20 32 Q14 26 14 20 Q14 14 20 8Z" fill="#fff"/>
          <circle cx="20" cy="20" r="4" fill="#fff"/>
        </svg>
      </div>
      <div class="logo-text">
        Northern Territory
        <span>Australia</span>
      </div>
    </a>
    <ul class="navbar__nav">
      <li><a href="#">Places to go</a></li>
      <li><a href="#">Things to do</a></li>
      <li><a href="#">Plan your trip</a></li>
      <li><a href="#" class="navbar__cta">Plan trip</a></li>
    </ul>
  </nav>
</header>
